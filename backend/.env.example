# Copy to .env and adjust. All variables are optional in development:
# without a .env the API runs with SQLite + local-memory cache.

# --- Core ---
DJANGO_SECRET_KEY=change-me-generate-a-long-random-string
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database (PostgreSQL in staging/production) ---
# DATABASE_URL=postgres://network:network@localhost:5432/network

# --- Cache / Redis ---
# REDIS_URL=redis://localhost:6379/0

# --- CORS (frontend origins) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Throttling ---
# THROTTLE_ANON=60/min
# THROTTLE_USER=600/min

# --- Uploads ---
# MAX_UPLOAD_SIZE=5242880
